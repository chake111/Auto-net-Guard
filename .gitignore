# AutoNetGuard .gitignore

# ── 敏感配置文件（含账号密码，绝不提交）──────────────────────────────────
config.ini

# ── 运行时文件 ────────────────────────────────────────────────────────────
guardian.pid

# ── 日志文件 ──────────────────────────────────────────────────────────────
*.log
service.log

# ── PyInstaller 构建产物 ───────────────────────────────────────────────────
build/
dist/
*.spec

# ── Python 缓存 ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── 虚拟环境 ──────────────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── IDE / 编辑器 ──────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── 系统文件 ──────────────────────────────────────────────────────────────
Thumbs.db
.DS_Store
