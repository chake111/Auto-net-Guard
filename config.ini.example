; AutoNetGuard 配置文件模板
; 使用方法：将此文件复制为 config.ini，然后填写你的账号和密码
;   Windows:      copy config.ini.example config.ini
;   Linux/macOS:  cp config.ini.example config.ini
;
; 注意：config.ini 包含敏感凭据，请勿提交到版本控制系统。
;
; ── 凭据加密说明 ──────────────────────────────────────────────────────────
; 首次运行时，程序会自动使用与当前机器绑定的密钥（基于 Windows MachineGuid
; 或主机名+MAC 地址，经 PBKDF2-HMAC-SHA256 派生）对 user_account 和
; user_password 进行 Fernet 对称加密，并将加密后的值（以 "ENC:" 为前缀）
; 回写到 config.ini，明文密码不再落盘。
;
; 如果将 config.ini 复制到其他机器，由于密钥不同将无法解密；此时只需将
; user_account 和 user_password 恢复为明文，重新启动程序即可自动完成加密。
;
; ── 多网络环境（Profile）说明 ─────────────────────────────────────────────
; 通过 [global] active_profile 指定当前生效的网络环境（Profile）。
; 每个 Profile 用 [profile:<名称>] 节定义，包含该环境专属的账号、密码和网关。
; 在系统托盘右键菜单的"切换网络环境"子菜单中可一键热切换，无需重启程序。
;
; 若不使用多 Profile 功能，保留传统 [credentials] / [network] 节即可，
; 删除 [global] 节或将 active_profile 留空，程序会自动回退到传统模式。


; ── 全局配置 ──────────────────────────────────────────────────────────────
[global]
; 当前生效的网络环境名称，必须与某个 [profile:<名称>] 节对应。
; 留空则回退到传统 [credentials] / [network] 节。
active_profile = school


; ── 网络环境 Profile 示例 ─────────────────────────────────────────────────
; 每个 Profile 可独立配置账号、密码和网关参数。

[profile:school]
; 校园网登录账号（通常为学号@运营商，例如 2331020130239@unicom）
user_account = YOUR_STUDENT_ID@unicom

; 校园网登录密码
user_password = YOUR_PASSWORD

; 认证网关 IP
gateway_ip = 10.10.10.2

; 登录接口完整 URL
login_url = http://10.10.10.2:801/eportal/portal/login

; HTTP Referer 头
referer = http://10.10.10.2/

; 无线控制器 IP（从抓包的登录请求中获取）
wlan_ac_ip = 10.0.253.2

; 无线控制器名称（从抓包的登录请求中获取）
wlan_ac_name = WS6812


[profile:company]
; 公司网络账号
user_account = YOUR_EMPLOYEE_ID@company

; 公司网络密码
user_password = YOUR_COMPANY_PASSWORD

; 公司网关 IP
gateway_ip = 192.168.1.1

; 公司登录接口 URL
login_url = http://192.168.1.1:801/eportal/portal/login

; HTTP Referer 头
referer = http://192.168.1.1/

; 无线控制器 IP
wlan_ac_ip = 192.168.1.254

; 无线控制器名称
wlan_ac_name = CompanyAP


; ── 传统凭据节（无 Profile 时使用） ──────────────────────────────────────
[credentials]
; 校园网登录账号（通常为学号@运营商，例如 2331020130239@unicom）
user_account = YOUR_STUDENT_ID@unicom

; 校园网登录密码
user_password = YOUR_PASSWORD


[network]
; 校园网认证网关 IP
gateway_ip = 10.10.10.2

; 登录接口完整 URL（一般无需修改）
login_url = http://10.10.10.2:801/eportal/portal/login

; HTTP Referer 头（一般无需修改）
referer = http://10.10.10.2/

; 无线控制器 IP（从抓包的登录请求中获取）
wlan_ac_ip = 10.0.253.2

; 无线控制器名称（从抓包的登录请求中获取）
wlan_ac_name = WS6812


[connectivity]
; 用于检测网络连通性的 URL，返回 HTTP 204 表示已联网
; 可替换为其他可靠的 204 端点，例如：
;   http://connect.rom.miui.com/generate_204
;   http://connectivitycheck.platform.hicloud.com/generate_204
check_url = http://www.google.cn/generate_204


[timing]
; 单次 HTTP 请求超时时间（秒）
request_timeout_seconds = 8

; 连通性检测超时时间（秒）
; 专用于判断当前是否已断网，建议比登录超时更短。
connectivity_timeout_seconds = 2

; 网络连通性检查间隔（秒）
check_interval_seconds = 30

; 断线/在线状态下的快速连通性检查间隔（秒）
; 用于更快发现主动注销、掉线以及恢复上线。
online_check_interval_seconds = 1

; 连续失败确认次数（次）
; 用于过滤单次网络抖动，达到该次数后才切换为离线并触发登录。
offline_debounce_failures = 2

; 登录失败后的最大重试次数
login_retry_count = 3

; 重试退避基础时间（秒），实际等待时间 = base * 2^(attempt-1)
backoff_base_seconds = 1


[logging]
; 日志文件路径（相对路径基于可执行文件所在目录）
log_file = service.log


[ui]
; 是否在网络状态发生实质性变化时弹出系统通知（true / false）
enable_notifications = true

; 通知冷却时间（秒）
; 用于抑制短时间内的重复状态通知。
status_notification_cooldown_seconds = 2


[auth]
; 认证协议类型，支持以下值：
;   drcom        – Dr.COM / Ruijie iPortal 校园网门户（默认，适用大多数高校）
;   generic_post – 通用 HTTP 表单认证（支持 GET/POST，参数由 [auth_params] 配置）
;   srun         – 深澜 (Srun) 校园网门户（挑战–响应 XXTEA 加密，适用深澜部署高校）
auth_type = drcom

; 以下选项仅在 auth_type = generic_post 时生效 ──────────────────────────────

; HTTP 请求方法：GET 或 POST（默认 POST）
; auth_method = POST

; 登录成功的响应体关键词（逗号分隔，不区分大小写）
; auth_success_markers = success,登录成功


[auth_params]
; 仅在 auth_type = generic_post 时使用。
; 此节的所有键值对将作为表单参数发送到 [network] login_url。
; 参数值支持以下占位符（运行时自动替换）：
;   {ip}           – 当前活跃网卡的 IPv4 地址
;   {mac}          – 当前活跃网卡的 MAC 地址（12 位小写十六进制，无分隔符）
;   {user_account} – [credentials] user_account 的值
;   {user_password}– [credentials] user_password 的值
;
; 示例（iNode / 深信服 Portal 等）：
; username   = {user_account}
; password   = {user_password}
; user_ip    = {ip}
; user_mac   = {mac}
; ac_id      = 1


[srun]
; 仅在 auth_type = srun 时使用。
;
; AC-ID：从学校门户登录页面源码或抓包中获取（通常为数字，常见值为 1）。
; acid = 1

